# Kyvik environment variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# Master encryption key (required for the secrets vault).
# Generate with:  openssl rand -base64 32
KYVIK_MASTER_KEY=

# Dashboard authentication
KYVIK_AUTH_USER=admin
KYVIK_AUTH_PASS=

# Model provider API keys (set at least one)
KYVIK_OPENROUTER_API_KEY=
# KYVIK_OPENROUTER_PROVISIONING_KEY=
# KYVIK_OPENAI_API_KEY=
# KYVIK_ANTHROPIC_API_KEY=

# Database DSN (optional)
# Setting this automatically switches the storage driver to postgres.
# KYVIK_DB_DSN=postgres://kyvik:kyvik@localhost:5432/kyvik?sslmode=disable

# Slack integration (optional)
# KYVIK_SLACK_BOT_TOKEN=
# KYVIK_SLACK_APP_TOKEN=
